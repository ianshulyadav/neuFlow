<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Portrait Toolbar Title -->
    <style name="Base.Theme.SpatialFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorSurfaceContainer">@color/md_theme_light_surfaceContainer</item>
        <item name="colorSurfaceContainerLow">@color/md_theme_light_surfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/md_theme_light_surfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/md_theme_light_surfaceContainerHighest</item>

        <item name="android:fontFamily">@font/google_flex</item>
        <item name="fontFamily">@font/google_flex</item>
        <item name="android:fontVariationSettings">"'ROND' 100"</item>
        <item name="fontVariationSettings">"'ROND' 100"</item>

        <item name="textAppearanceDisplayLarge">@style/TextAppearance.SpatialFlow.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.SpatialFlow.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.SpatialFlow.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.SpatialFlow.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.SpatialFlow.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.SpatialFlow.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.SpatialFlow.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.SpatialFlow.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.SpatialFlow.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.SpatialFlow.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.SpatialFlow.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.SpatialFlow.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.SpatialFlow.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.SpatialFlow.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.SpatialFlow.LabelSmall</item>

        <!-- System bars styling -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">true</item>

        <!-- Material 3 Expressive System Tokens -->
        <item name="motionDurationShort1">200</item>
        <item name="motionDurationShort2">250</item>
        <item name="motionDurationMedium1">400</item>
        <item name="motionDurationMedium2">500</item>
        <item name="motionDurationLong1">600</item>
        <item name="motionDurationLong2">700</item>
        <item name="motionEasingStandard">@android:interpolator/fast_out_slow_in</item>
        <item name="motionEasingEmphasized">@android:interpolator/fast_out_slow_in</item>

        <item name="linearProgressIndicatorStyle">@style/Widget.Material3Expressive.LinearProgressIndicator.Wavy</item>
    </style>
    <!-- Landscape Toolbar Title - Smaller -->


    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
            <item name="android:color">?attr/colorSecondaryContainer</item>
            <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
            <item name="android:width">64dp</item>
            <item name="android:height">32dp</item>
        </style>

    <style name="ShapeAppearance.SpatialFlow.ExtraLarge" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>

    <!-- ============================================ -->
    <!-- Material 3 Expressive Typography Styles -->
    <!-- ============================================ -->

    <!-- Display Styles - For large, impactful text -->
    <style name="TextAppearance.SpatialFlow.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">

        <item name="android:textSize">57sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineHeight">68sp</item>
        <item name="android:fontVariationSettings">"'wght' 400, 'ROND' 100"</item>
    </style>

    <style name="TextAppearance.SpatialFlow.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">

        <item name="android:textSize">45sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.SpatialFlow.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">

        <item name="android:textSize">36sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Headline Styles - For section titles -->
    <style name="TextAppearance.SpatialFlow.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">

        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.SpatialFlow.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">

        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0.018</item>
        <item name="android:lineHeight">42sp</item>
        <item name="android:fontVariationSettings">"'wght' 600, 'ROND' 100"</item>
    </style>

    <style name="TextAppearance.SpatialFlow.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">

        <item name="android:textSize">24sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Lyrics Style - For active song lyrics -->
    <style name="TextAppearance.SpatialFlow.Lyrics" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/google_flex</item>
        <item name="fontFamily">@font/google_flex</item>
        <item name="android:fontVariationSettings">"'wdth' 112, 'wght' 700, 'GRAD' 100, 'ROND' 100"</item>
        <item name="fontVariationSettings">"'wdth' 112, 'wght' 700, 'GRAD' 100, 'ROND' 100"</item>
    </style>

    <!-- Title Styles - For component headers -->
    <style name="TextAppearance.SpatialFlow.TitleLarge" parent="TextAppearance.Material3.TitleLarge">

        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0.023</item>
        <item name="android:lineHeight">32sp</item>
        <item name="android:fontVariationSettings">"'wght' 700, 'ROND' 100"</item>
    </style>

    <style name="TextAppearance.SpatialFlow.TitleMedium" parent="TextAppearance.Material3.TitleMedium">

        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.SpatialFlow.TitleSmall" parent="TextAppearance.Material3.TitleSmall">

        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Body Styles - For main content text -->
    <style name="TextAppearance.SpatialFlow.BodyLarge" parent="TextAppearance.Material3.BodyLarge">

        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:lineHeight">28sp</item>
        <item name="android:fontVariationSettings">"'wght' 400, 'ROND' 100"</item>
    </style>

    <style name="TextAppearance.SpatialFlow.BodyMedium" parent="TextAppearance.Material3.BodyMedium">

        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.036</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:fontVariationSettings">"'wght' 400, 'ROND' 100"</item>
    </style>

    <style name="TextAppearance.SpatialFlow.BodySmall" parent="TextAppearance.Material3.BodySmall">

        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- Label Styles - For buttons, chips, and small labels -->
    <style name="TextAppearance.SpatialFlow.LabelLarge" parent="TextAppearance.Material3.LabelLarge">

        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.007</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:fontVariationSettings">"'wght' 500, 'ROND' 100"</item>
    </style>

    <style name="TextAppearance.SpatialFlow.LabelMedium" parent="TextAppearance.Material3.LabelMedium">

        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.SpatialFlow.LabelSmall" parent="TextAppearance.Material3.LabelSmall">

        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.045</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:fontVariationSettings">"'wght' 500, 'ROND' 100"</item>
    </style>

