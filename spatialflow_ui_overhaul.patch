+        val pixels = IntArray(bitmap.width * bitmap.height)
+        bitmap.getPixels(pixels, 0, bitmap.width, 0, 0, bitmap.width, bitmap.height)
+        Color(selectSeedArgb(pixels, config))
+    }.getOrElse { Color(0xFF6750A4) }
