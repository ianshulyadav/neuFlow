+
+private fun averageArgb(pixels: IntArray): Int { if(pixels.isEmpty()) return 0xFF6750A4.toInt(); var r=0L;var g=0L;var b=0L; for(a in pixels){r+=(a ushr 16)and 0xFF;g+=(a ushr 8)and 0xFF;b+=a and 0xFF}; val s=pixels.size.toLong(); return (0xFF shl 24)or((r/s).toInt()shl 16)or((g/s).toInt()shl 8)or(b/s).toInt()}
